# ==== Telegram ====
TELEGRAM_BOT_TOKEN=your_bot_token_from_BotFather

# ==== ProxyAPI (один ключ — оба провайдера) ====
# Получить: https://console.proxyapi.ru/keys
PROXYAPI_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_BASE_URL=https://api.proxyapi.ru/anthropic
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1

# ==== Модели ====
MODEL_HAIKU=claude-haiku-4-5
MODEL_SONNET=claude-sonnet-4-5
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ==== X (Twitter) — для tweety-ns ====
# Используй отдельный технический аккаунт, не основной.
X_USERNAME=
X_PASSWORD=
X_SESSION_NAME=x_news_bot_session

# ==== Хранилища ====
DATABASE_URL=sqlite+aiosqlite:///./bot.db
CHROMA_PATH=./chroma_db

# ==== Расписание ====
DEFAULT_DELIVERY_INTERVAL_HOURS=3
FETCH_INTERVAL_MINUTES=30
